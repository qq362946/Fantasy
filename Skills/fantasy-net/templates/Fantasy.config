<?xml version="1.0" encoding="utf-8" ?>
<fantasy xmlns="http://fantasy.net/config"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://fantasy.net/config Fantasy.xsd">

  <!-- ══════════════════════════════════════════════════════════════
       ID 生成策略（可选，默认 Default）
         Default  — 默认策略，Scene 数量上限 65535
         World    — ID 中包含 World 信息，自动规避合区 ID 冲突；
                    Scene 数量上限 255，Scene ID 须在
                    worldId*1000+1 ~ worldId*1000+255 范围内，
                    World ID 不能超过 255
  ══════════════════════════════════════════════════════════════ -->
  <idFactory type="Default"/>

  <!-- ══════════════════════════════════════════════════════════════
       内网通讯协议与消息大小（可选，有默认值）
         inner          — 服务器间内网协议：TCP | KCP | WebSocket
                          默认 TCP
         maxMessageSize — 单条消息最大字节数，默认 1048560 (≈1 MB)
  ══════════════════════════════════════════════════════════════ -->
  <network inner="TCP" maxMessageSize="1048560" />

  <!-- ══════════════════════════════════════════════════════════════
       Session 空闲检测（可选，有默认值）
         idleTimeout  — 空闲超时时间（毫秒），超过后断开连接，默认 8000
         idleInterval — 空闲检测轮询间隔（毫秒），默认 5000
  ══════════════════════════════════════════════════════════════ -->
  <session idleTimeout="8000" idleInterval="5000" />

  <server>

    <!-- ════════════════════════════════════════════════════════════
         物理/虚拟机器列表（至少一条，不能为空）
           id          — 机器唯一 ID，uint，不能为 0，不能重复
           outerIP     — 对外公网 IP（客户端连接用）
           outerBindIP — 外网监听绑定 IP（本地测试填 127.0.0.1）
           innerBindIP — 内网监听绑定 IP（服务器间通讯，本地测试填 127.0.0.1）
    ════════════════════════════════════════════════════════════ -->
    <machines>
      <machine id="1" outerIP="127.0.0.1" outerBindIP="127.0.0.1" innerBindIP="127.0.0.1" />
    </machines>

    <!-- ════════════════════════════════════════════════════════════
         进程列表（至少一条，每个操作系统进程对应一条）
           id           — 进程唯一 ID，uint，不能为 0，不能重复
           machineId    — 所属机器 ID，必须引用已存在的 <machine id>
           startupGroup — 启动分组，控制多进程启动顺序，0 表示不分组
    ════════════════════════════════════════════════════════════ -->
    <processes>
      <process id="1" machineId="1" startupGroup="0" />
    </processes>

    <!-- ════════════════════════════════════════════════════════════
         区服（World）列表（至少一条）
           id        — World 唯一 ID，uint，不能重复；
                       使用 idFactory type="World" 时不能超过 255
           worldName — World 名称，仅用于标识

         子节点 <database>（可选，可配置多个）：
           dbType      — 数据库类型，目前支持：MongoDB
           dbName      — 数据库名称，同一 World 内不能重复
           dbConnection— 连接字符串，为空时该条配置被忽略（不实际连接）
           isDefault   — 是否为默认库，bool，默认 false；
                         不设置时自动使用第一条作为默认库；
                         多条时第一个 isDefault=true 的生效，其余忽略
    ════════════════════════════════════════════════════════════ -->
    <worlds>
      <world id="1" worldName="World1">
        <database dbType="MongoDB" dbName="fantasy_main" dbConnection="" isDefault="true" />
        <!-- 同一 World 可配置多个数据库 -->
        <!-- <database dbType="MongoDB" dbName="fantasy_log" dbConnection="" /> -->
      </world>
    </worlds>

    <!-- ════════════════════════════════════════════════════════════
         Scene 列表（至少一条，Scene 是服务器的逻辑运行单元）
           id               — Scene 唯一 ID，uint，不能为 0，不能重复；
                              使用 idFactory type="World" 时须在
                              worldId*1000+1 ~ worldId*1000+255 范围内
           processConfigId  — 所属进程 ID，必须引用已存在的 <process id>
           worldConfigId    — 所属 World ID，必须引用已存在的 <world id>，不能为 0
           sceneRuntimeMode — Scene 运行线程模式：
                                MainThread  — 运行在主线程
                                MultiThread — 运行在独立线程（推荐）
                                ThreadPool  — 运行在线程池（按 CPU 核心数分配）
           sceneTypeString  — Scene 类型名，对应 SceneType 中定义的常量名
                              （如 Gate / Map / Chat / Addressable / HttpGift 等）
           networkProtocol  — 外网协议，outerPort > 0 时必须填：
                                KCP       — KCP 协议（低延迟，推荐游戏客户端）
                                TCP       — TCP 协议
                                WebSocket — WebSocket 协议（Web 客户端）
                                HTTP      — HTTP 协议（REST API）
                              无外网时留空或省略
           outerPort        — 外网监听端口，0 表示不对外暴露；
                              同一机器上不能与其他 Scene 的端口冲突
           innerPort        — 内网监听端口，不能为 0；
                              同一机器上不能与其他 Scene 的端口冲突
    ════════════════════════════════════════════════════════════ -->
    <scenes>
      <!-- 示例：Gate Scene（客户端接入，KCP 外网） -->
      <scene id="1001" processConfigId="1" worldConfigId="1"
             sceneRuntimeMode="MultiThread" sceneTypeString="Gate"
             networkProtocol="KCP" outerPort="20000" innerPort="11001"/>

      <!-- 示例：纯内网 Scene（无外网端口） -->
      <!-- <scene id="1002" processConfigId="1" worldConfigId="1"
               sceneRuntimeMode="MultiThread" sceneTypeString="Map"
               networkProtocol="" outerPort="0" innerPort="11002"/> -->

      <!-- 示例：HTTP REST API Scene -->
      <!-- <scene id="1003" processConfigId="1" worldConfigId="1"
               sceneRuntimeMode="MultiThread" sceneTypeString="HttpGift"
               networkProtocol="HTTP" outerPort="20010" innerPort="11003"/> -->
    </scenes>

  </server>
</fantasy>
