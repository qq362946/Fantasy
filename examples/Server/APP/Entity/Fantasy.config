<?xml version="1.0" encoding="utf-8" ?>
<fantasy xmlns="http://fantasy.net/config" 
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://fantasy.net/config Fantasy.xsd">
  <!--
    ID生成策略（可选，默认Default）。
    Default：支持最多65535个Scene。
    World：ID中包含World信息，用于规避合区ID冲突；
           World ID不能超过255，每个World的Scene ID必须位于
           worldId*1000+1到worldId*1000+255之间。
  -->
  <idFactory type="Default"/>

  <!--
    网络运行配置。
    inner：服务器内部通信协议，可选TCP或KCP，默认TCP。
    maxMessageSize：单条消息最大字节数，默认1048560（约1 MB）。
  -->
  <network inner="TCP" maxMessageSize="1048560" />

  <!--
    Session空闲检测配置。
    idleTimeout：空闲超时时间（毫秒），超过后断开连接，默认8000。
    idleInterval：空闲检测间隔（毫秒），默认5000。
  -->
  <session idleTimeout="8000" idleInterval="5000" />

  <!--
    Fantasy Control Center 配置。

    enabled:
      是否启用 Control Center。
      false 时完全使用下面的 <server> 本地配置。
      true 时从 Control Center 获取 Machine、Process、World、Database、Scene 配置。

    url:
      Control Center 的 HTTP 地址，不要以 /api/v1 结尾。

    fallbackToLocal:
      Control Center 启动连接失败时，是否回退到下面的 <server> 本地配置。
      true  表示允许回退，本地 <server> 必须保留完整配置。
      false 表示不允许回退，Control Center 不可用时服务器启动失败。
      
    heartbeatIntervalSeconds:
      批量心跳发送间隔，单位为秒。
      必须大于0并小于leaseSeconds。

    leaseSeconds:
      服务实例租约时长，单位为秒，范围为5到300秒。
      建议至少是heartbeatIntervalSeconds的3倍。      
  -->
  <controlCenter
    enabled="true"
    url="http://127.0.0.1:5277"
    fallbackToLocal="true"
    heartbeatIntervalSeconds="5"
    leaseSeconds="15">

    <!--
      服务发现模式下的Scene类型声明。

      这里定义的是编译期Scene类型，不是运行时Scene实例。
      Control Center返回SceneType字符串后，Fantasy.Net使用这里
      生成的SceneType常量和字典完成转换。

      id:
        Scene类型的稳定数字ID。
        ID必须大于0、不能重复，发布后不要修改或重复使用。

      name:
        Scene类型名称。
        必须与Control Center中配置的SceneType完全一致。
        名称必须以大写字母开头，只能包含字母、数字和下划线。        
         
      新增已有类型的Scene实例不需要重新编译。
      只有增加全新的Scene类型时，才需要修改这里并重新编译。
    -->
    <sceneTypes>
      <sceneType id="1" name="Gate"/>
      <sceneType id="2" name="Map"/>
      <sceneType id="3" name="HttpGift"/>
      <sceneType id="4" name="Addressable"/>
      <sceneType id="5" name="Chat"/>
    </sceneTypes>

  </controlCenter>

  <!--
    本地服务器配置。

    未启用 Control Center 时：
      下面的 Machine、Process、World、Scene 配置正常生效，
      SceneType 继续根据 <scenes> 中的 sceneTypeString 自动生成。

    启用 Control Center 且连接成功时：
      整个 <server> 配置不会加载，运行时配置全部来自 Control Center。

    启用 Control Center 且 fallbackToLocal="true" 时：
      只有 Control Center 连接或配置加载失败，才会使用这里的配置。
      本地 <scenes> 使用的 sceneTypeString 必须已经声明在
      <controlCenter><sceneTypes> 中。
  -->
  <server>
    <!--
      机器配置，至少需要一条。
      id：机器唯一ID，必须大于0且不能重复。
      outerIP：对外公网IP，供客户端连接。
      outerBindIP：外网监听绑定IP。
      innerBindIP：服务器内部通信监听绑定IP。
    -->
    <machines>
      <machine id="1" outerIP="127.0.0.1" outerBindIP="127.0.0.1" innerBindIP="127.0.0.1" />
    </machines>
    
    <!--
      进程配置，至少需要一条。
      id：进程唯一ID，必须大于0且不能重复。
      namespaceId：所属Namespace ID。未启用Control Center时可省略；
                   从Control Center回退到本地配置时必须大于0。
      machineId：所属机器ID，必须引用已存在的machine。
      startupGroup：启动分组，用于控制多进程启动顺序，0表示不分组。
    -->
    <processes>
      <process id="1" namespaceId="1" machineId="1" startupGroup="1" />
    </processes>

    <!--
      World配置，至少需要一条。
      id：World唯一ID，不能重复；使用World ID生成策略时不能超过255。
      namespaceId：所属Namespace ID。未启用Control Center时可省略；
                   从Control Center回退到本地配置时必须大于0。
      groupId：所属WorldGroup ID。未启用Control Center时可省略；
               从Control Center回退到本地配置时必须大于0。
      worldName：World名称。

      database子节点：
      dbType：数据库类型。
      dbName：数据库名称，同一World内不能重复。
      dbConnection：数据库连接字符串，允许为空。
      isDefault：是否为该World的默认数据库，默认false；
                 未指定默认库时使用第一条数据库配置。
    -->
    <worlds>
      <world id="1" namespaceId="1" groupId="1" worldName="WorldA">
        <database dbType="MongoDB" dbName="fantasy_main1" isDefault="true" dbConnection=""/>
        <database dbType="MongoDB" dbName="fantasy_main2" dbConnection=""/>
        </world>
      <world id="2" namespaceId="1" groupId="1" worldName="WorldB"> 
        <database dbType="MongoDB" dbName="doc" dbConnection=""/>
      </world>
    </worlds>

    <!--
      Scene配置，至少需要一条。
      id：Scene唯一ID，必须大于0且不能重复。
      processConfigId：所属进程ID，必须引用已存在的process。
      worldConfigId：所属World ID，必须引用已存在的world。
      sceneRuntimeMode：运行线程模式，可选MainThread、MultiThread、ThreadPool。
      sceneTypeString：Scene类型名称。
      networkProtocol：外网协议，可选TCP、KCP、WebSocket、HTTP；无外网时留空。
      outerPort：外网监听端口，0表示不对外开放。
      innerPort：内网监听端口，必须大于0。
      同一机器上的所有内外网端口不能冲突。
    -->
    <scenes>
      <scene id="1001" processConfigId="1" worldConfigId="1" sceneRuntimeMode="MultiThread" 
             sceneTypeString="Addressable" networkProtocol="" outerPort="0" innerPort="11001"/>
      <scene id="1002" processConfigId="1" worldConfigId="1" sceneRuntimeMode="MultiThread" 
             sceneTypeString="Gate" networkProtocol="KCP" outerPort="20000" innerPort="11002"/>
      <scene id="1003" processConfigId="1" worldConfigId="1" sceneRuntimeMode="MultiThread" 
             sceneTypeString="Map" networkProtocol="" outerPort="0" innerPort="11003"/>
      <scene id="1004" processConfigId="1" worldConfigId="1" sceneRuntimeMode="MultiThread" 
             sceneTypeString="Chat" networkProtocol="" outerPort="0" innerPort="11004"/>
      <scene id="1006" processConfigId="1" worldConfigId="1" sceneRuntimeMode="MultiThread" 
             sceneTypeString="HttpGift" networkProtocol="HTTP" outerPort="20010" innerPort="11006"/>
      <scene id="2001" processConfigId="1" worldConfigId="2" sceneRuntimeMode="MultiThread" 
             sceneTypeString="Map" networkProtocol="" outerPort="0" innerPort="11005"/>
    </scenes>
  </server>
</fantasy>
