@using System.Globalization
@inherits InputBase<uint>

<input @attributes="AdditionalAttributes"
       type="number"
       min="0"
       max="@uint.MaxValue"
       step="1"
       class="@CssClass"
       value="@CurrentValueAsString"
       @onchange="HandleChange" />

@code {
    protected override bool TryParseValueFromString(
        string? value,
        out uint result,
        out string validationErrorMessage)
    {
        if (uint.TryParse(value, NumberStyles.None, CultureInfo.InvariantCulture, out result))
        {
            validationErrorMessage = string.Empty;
            return true;
        }

        validationErrorMessage = $"{FieldIdentifier.FieldName} 必须是 0 到 {uint.MaxValue} 之间的整数。";
        return false;
    }

    private void HandleChange(ChangeEventArgs eventArgs) =>
        CurrentValueAsString = eventArgs.Value?.ToString() ?? string.Empty;
}
