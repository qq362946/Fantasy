<?xml version="1.0" encoding="utf-8" ?>
<fantasy xmlns="http://fantasy.net/config" 
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://fantasy.net/config Fantasy.xsd">
  <!--
    ID生成策略（可选，默认Default）。
    Default：支持最多65535个Scene。
    World：ID中包含World信息，用于规避合区ID冲突；
           World ID不能超过255，每个World的Scene ID必须位于
           worldId*1000+1到worldId*1000+255之间。
  -->
  <idFactory type="Default"/>

  <!--
    网络运行配置。
    inner：服务器内部通信协议，可选TCP或KCP，默认TCP。
    maxMessageSize：单条消息最大字节数，默认1048560（约1 MB）。
  -->
  <network inner="TCP" maxMessageSize="1048560" />

  <!--
    Session空闲检测配置。
    idleTimeout：空闲超时时间（毫秒），超过后断开连接，默认8000。
    idleInterval：空闲检测间隔（毫秒），默认5000。
  -->
  <session idleTimeout="8000" idleInterval="5000" />

  <!--
    Fantasy Control Center与服务发现配置示例。

    enabled:
      是否启用Control Center。
      false时完全使用下面的server本地配置。
      true时从Control Center获取Machine、Process、World、Database、Scene配置。

    url:
      Control Center的HTTP地址，不要包含/api/v1路径。

    fallbackToLocal:
      Control Center连接或配置加载失败时，是否回退到下面的server本地配置。
      true表示允许回退，server必须保留完整配置。
      false表示不允许回退，Control Center不可用时服务器启动失败。
      
    heartbeatIntervalSeconds:
      批量心跳发送间隔，单位为秒。
      必须大于0并小于leaseSeconds。

    leaseSeconds:
      服务实例租约时长，单位为秒，范围为5到300秒。
      建议至少是heartbeatIntervalSeconds的3倍。      

    sceneTypes:
      仅在enabled=true时使用，声明服务发现模式下的编译期Scene类型。
      id必须大于0、不能重复，发布后不要修改或重复使用。
      name必须与Control Center中的SceneType完全一致，并以大写字母开头。
      新增已有类型的Scene实例不需要重新编译；增加全新类型时才需要修改这里。

    如需启用，请取消下面controlCenter节点的注释。

    <controlCenter enabled="true"
                   url="http://127.0.0.1:5000"
                   fallbackToLocal="true"
                   heartbeatIntervalSeconds="5"
                   leaseSeconds="15">
      <sceneTypes>
        <sceneType id="1" name="Gate"/>
      </sceneTypes>
    </controlCenter>
  -->

  <!--
    本地服务器配置。
    未启用Control Center时正常生效。
    Control Center连接成功时不加载；fallbackToLocal=true且加载失败时作为兜底。
  -->
  <server>
    <!--
      机器配置，至少需要一条。
      id：机器唯一ID，必须大于0且不能重复。
      outerIP：对外公网IP，供客户端连接。
      outerBindIP：外网监听绑定IP。
      innerBindIP：服务器内部通信监听绑定IP。
    -->
    <machines>
      <machine id="1" outerIP="127.0.0.1" outerBindIP="127.0.0.1" innerBindIP="127.0.0.1" />
    </machines>
    <!--
      进程配置，至少需要一条。
      id：进程唯一ID，必须大于0且不能重复。
      namespaceId：所属Namespace ID。未启用Control Center时可省略；
                   从Control Center回退到本地配置时必须大于0。
      machineId：所属机器ID，必须引用已存在的machine。
      startupGroup：启动分组，用于控制多进程启动顺序，0表示不分组。
    -->
    <processes>
      <process id="1" namespaceId="1" machineId="1" startupGroup="0" />
    </processes>
    <!--
      World配置，至少需要一条。
      id：World唯一ID，不能重复；使用World ID生成策略时不能超过255。
      namespaceId：所属Namespace ID。未启用Control Center时可省略；
                   从Control Center回退到本地配置时必须大于0。
      groupId：所属WorldGroup ID。未启用Control Center时可省略；
               从Control Center回退到本地配置时必须大于0。
      worldName：World名称。

      database子节点：
      dbType：数据库类型。
      dbName：数据库名称，同一World内不能重复。
      dbConnection：数据库连接字符串，允许为空。
      isDefault：是否为该World的默认数据库，默认false；
                 未指定默认库时使用第一条数据库配置。
    -->
    <worlds>
      <world id="1" namespaceId="1" groupId="1" worldName="WorldA">
        <database dbType="MongoDB" dbName="fantasy_main" dbConnection=""/>
      </world>
    </worlds>
    <!--
      Scene配置，至少需要一条。
      id：Scene唯一ID，必须大于0且不能重复。
      processConfigId：所属进程ID，必须引用已存在的process。
      worldConfigId：所属World ID，必须引用已存在的world。
      sceneRuntimeMode：运行线程模式，可选MainThread、MultiThread、ThreadPool。
      sceneTypeString：Scene类型名称。
      networkProtocol：外网协议，可选TCP、KCP、WebSocket、HTTP；无外网时留空。
      outerPort：外网监听端口，0表示不对外开放。
      innerPort：内网监听端口，必须大于0。
      同一机器上的所有内外网端口不能冲突。
    -->
    <scenes>
      <scene id="1001" 
             processConfigId="1" 
             worldConfigId="1" 
             sceneRuntimeMode="MultiThread" 
             sceneTypeString="Gate" 
             networkProtocol="KCP" 
             outerPort="20000" innerPort="11002" />
    </scenes>
  </server>
</fantasy>
