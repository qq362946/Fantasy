<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Fantasy.ProtocolEditor.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Fantasy.ProtocolEditor.Views.ExportSettingsView"
             x:DataType="vm:ExportSettingsViewModel"
             Background="#1E1E1E">

    <Grid RowDefinitions="Auto,*" Margin="10">
        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="#2D2D30" CornerRadius="4" Padding="10" Margin="0,0,0,10">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="协议导出配置"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="#FFFFFF"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="{Binding SaveMessage}"
                               FontSize="12"
                               Foreground="#4CAF50"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <Button Content="保存"
                            Command="{Binding SaveConfigCommand}"
                            IsEnabled="{Binding IsModified}"
                            Background="#007ACC"
                            Foreground="White"
                            Padding="15,5"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <ScrollViewer Grid.Row="1" AllowAutoHide="False">
            <ScrollViewer.Styles>
                <Style Selector="ScrollBar">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="Transitions" Value="{x:Null}"/>
                </Style>
                <Style Selector="ScrollBar:vertical">
                    <Setter Property="Transitions" Value="{x:Null}"/>
                </Style>
                <Style Selector="ScrollBar:horizontal">
                    <Setter Property="Transitions" Value="{x:Null}"/>
                </Style>
            </ScrollViewer.Styles>
            <StackPanel Margin="10" Spacing="15">

            <!-- 工作区路径（只读） -->
            <StackPanel Spacing="5">
                <TextBlock Text="协议目录（工作区路径）"
                           FontWeight="SemiBold"
                           Foreground="#CCCCCC"/>
                <Border Background="#252526"
                        BorderBrush="#3E3E42"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10">
                    <TextBlock Text="{Binding WorkspacePath}"
                               FontFamily="Consolas,Menlo,Monaco,monospace"
                               TextWrapping="Wrap"
                               Foreground="#858585"/>
                </Border>
                <TextBlock Text="💡 协议目录自动使用当前打开的工作区路径"
                           FontSize="12"
                           Foreground="#858585"/>
            </StackPanel>

            <Separator Background="#3E3E42"/>

            <!-- 服务器配置 -->
            <StackPanel Spacing="5">
                <CheckBox IsChecked="{Binding ExportToServer}"
                          Content="导出到服务器"
                          FontWeight="SemiBold"
                          Foreground="#CCCCCC"/>

                <StackPanel Spacing="5" IsEnabled="{Binding ExportToServer}">
                    <TextBlock Text="服务器输出目录"
                               Foreground="#CCCCCC"/>
                    <TextBox Text="{Binding ServerOutputDirectory}"
                             Watermark="例如: /path/to/server/output"
                             FontFamily="Consolas,Menlo,Monaco,monospace"
                             Background="#252526"
                             Foreground="#CCCCCC"
                             BorderBrush="#3E3E42"/>
                    <TextBlock Text="💡 服务器端生成的协议代码将保存到此目录"
                               FontSize="12"
                               Foreground="#858585"/>
                </StackPanel>
            </StackPanel>

            <Separator Background="#3E3E42"/>

            <!-- 客户端配置 -->
            <StackPanel Spacing="5">
                <CheckBox IsChecked="{Binding ExportToClient}"
                          Content="导出到客户端"
                          FontWeight="SemiBold"
                          Foreground="#CCCCCC"/>

                <StackPanel Spacing="5" IsEnabled="{Binding ExportToClient}">
                    <TextBlock Text="客户端输出目录"
                               Foreground="#CCCCCC"/>
                    <TextBox Text="{Binding ClientOutputDirectory}"
                             Watermark="例如: /path/to/client/output"
                             FontFamily="Consolas,Menlo,Monaco,monospace"
                             Background="#252526"
                             Foreground="#CCCCCC"
                             BorderBrush="#3E3E42"/>
                    <TextBlock Text="💡 客户端生成的协议代码将保存到此目录"
                               FontSize="12"
                               Foreground="#858585"/>
                </StackPanel>
            </StackPanel>

            <Separator Background="#3E3E42"/>

            <!-- 子包协议配置 -->
            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="3">
                        <TextBlock Text="子包协议（PackageExports）"
                                   FontWeight="SemiBold"
                                   Foreground="#CCCCCC"/>
                        <TextBlock Text="每个子包可以使用独立的协议目录、输出目录和导出目标"
                                   FontSize="12"
                                   Foreground="#858585"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="＋ 添加子包"
                            Command="{Binding AddPackageExportCommand}"
                            Background="#3A3D41"
                            Foreground="#FFFFFF"
                            Padding="12,5"
                            VerticalAlignment="Center"/>
                </Grid>

                <ItemsControl ItemsSource="{Binding PackageExports}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PackageExportItemViewModel">
                            <Border Background="#252526"
                                    BorderBrush="#3E3E42"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                <StackPanel Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="1"
                                                Content="删除"
                                                Command="{Binding $parent[ItemsControl].((vm:ExportSettingsViewModel)DataContext).RemovePackageExportCommand}"
                                                CommandParameter="{Binding}"
                                                Background="#5A2D2D"
                                                Foreground="#FFFFFF"
                                                Padding="10,4"/>
                                    </Grid>

                                    <StackPanel Spacing="5">
                                        <TextBlock Text="子包协议目录"
                                                   Foreground="#CCCCCC"/>
                                        <TextBox Text="{Binding ProtocolDirectory}"
                                                 Watermark="例如: ../Fantasy.Room/Protocol"
                                                 FontFamily="Consolas,Menlo,Monaco,monospace"
                                                 Background="#1E1E1E"
                                                 Foreground="#CCCCCC"
                                                 BorderBrush="#3E3E42"/>
                                        <TextBlock Text="💡 相对路径以当前协议工作区为基准"
                                                   FontSize="12"
                                                   Foreground="#858585"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="20">
                                        <CheckBox IsChecked="{Binding ExportToServer}"
                                                  Content="导出到服务器"
                                                  Foreground="#CCCCCC"/>
                                        <CheckBox IsChecked="{Binding ExportToClient}"
                                                  Content="导出到客户端"
                                                  Foreground="#CCCCCC"/>
                                    </StackPanel>

                                    <StackPanel Spacing="5" IsEnabled="{Binding ExportToServer}">
                                        <TextBlock Text="子包服务器输出目录"
                                                   Foreground="#CCCCCC"/>
                                        <TextBox Text="{Binding ServerOutputDirectory}"
                                                 Watermark="例如: ../Fantasy.Room/Runtime/Protocol"
                                                 FontFamily="Consolas,Menlo,Monaco,monospace"
                                                 Background="#1E1E1E"
                                                 Foreground="#CCCCCC"
                                                 BorderBrush="#3E3E42"/>
                                    </StackPanel>

                                    <StackPanel Spacing="5" IsEnabled="{Binding ExportToClient}">
                                        <TextBlock Text="子包客户端输出目录"
                                                   Foreground="#CCCCCC"/>
                                        <TextBox Text="{Binding ClientOutputDirectory}"
                                                 Watermark="例如: ../Fantasy.Room.Unity/Runtime/Protocol"
                                                 FontFamily="Consolas,Menlo,Monaco,monospace"
                                                 Background="#1E1E1E"
                                                 Foreground="#CCCCCC"
                                                 BorderBrush="#3E3E42"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <Separator Background="#3E3E42"/>

            <!-- 验证状态 -->
            <Border Background="{Binding IsValid, Converter={StaticResource BoolToValidationBackground}}"
                    BorderBrush="{Binding IsValid, Converter={StaticResource BoolToValidationBorder}}"
                    BorderThickness="2"
                    CornerRadius="4"
                    Padding="12">
                <TextBlock Text="{Binding ValidationMessage}"
                           TextWrapping="Wrap"
                           FontWeight="Medium"
                           Foreground="#FFFFFF"/>
            </Border>

            <!-- 说明 -->
            <StackPanel Spacing="5">
                <TextBlock Text="使用说明"
                           FontWeight="SemiBold"
                           Foreground="#CCCCCC"/>
                <Border Background="#252526"
                        BorderBrush="#3E3E42"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12">
                    <StackPanel Spacing="5">
                        <TextBlock Text="1. 协议目录使用当前工作区路径，包含 Inner 和 Outer 子文件夹"
                                   TextWrapping="Wrap"
                                   Foreground="#858585"/>
                        <TextBlock Text="2. 配置主协议服务器和客户端的输出目录"
                                   TextWrapping="Wrap"
                                   Foreground="#858585"/>
                        <TextBlock Text="3. 可在 PackageExports 区域新增、删除并配置子包协议"
                                   TextWrapping="Wrap"
                                   Foreground="#858585"/>
                        <TextBlock Text="4. 主协议和每个子包都至少选择一个导出目标"
                                   TextWrapping="Wrap"
                                   Foreground="#858585"/>
                        <TextBlock Text="5. 点击保存后会写入协议工作区根目录的 ExporterSettings.json"
                                   TextWrapping="Wrap"
                                   Foreground="#858585"/>
                        <TextBlock Text="6. 使用菜单「文件 → 执行导出」执行导出"
                                   TextWrapping="Wrap"
                                   Foreground="#858585"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
